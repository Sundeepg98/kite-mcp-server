# Kite MCP Server — Environment Configuration
# =============================================
# Copy this file to ".env" and update with your actual values.
# Register at https://developers.kite.trade/signup for Kite API credentials.
#
# The envcheck at startup (app/envcheck.go) validates critical vars
# and will abort on malformed values. See docs/env-vars.md for the
# full inventory.

# --- Required for OAuth / multi-user ---
# Multi-user HTTP mode requires both OAUTH_JWT_SECRET and EXTERNAL_URL.
# If OAUTH_JWT_SECRET is unset and no Kite API key is provided, the
# server refuses to start.

OAUTH_JWT_SECRET=<generate with openssl rand -hex 32>  # HKDF seed for AES-256-GCM + JWT HMAC. Min 32 bytes. Rotating invalidates stored OAuth clients, cached Kite tokens, sessions.
EXTERNAL_URL=https://your-domain.example.com           # Public HTTPS origin, no trailing slash. Baked into every OAuth callback URL.

# --- Required for Kite Connect ---
# Two modes:
#   (a) Single-user: set KITE_API_KEY + KITE_API_SECRET (developer app)
#   (b) Multi-user:  leave these empty; users bring their own via
#                    mcp-remote oauth_client_id/oauth_client_secret.
# KITE_ACCESS_TOKEN is a local-dev shortcut that bypasses the browser login.

KITE_API_KEY=            # Kite Connect API key (developer app). Leave empty for per-user OAuth-only deployments.
KITE_API_SECRET=         # Kite Connect API secret. Required when KITE_API_KEY is set.
# KITE_ACCESS_TOKEN=     # Optional: dev-only. Skips browser login. Token expires ~6 AM IST daily.

# --- Optional infrastructure ---

APP_MODE=http            # Transport: http | sse | stdio | hybrid. Default: http.
APP_PORT=8080            # HTTP port. Default: 8080.
APP_HOST=0.0.0.0         # Bind host. Default: 0.0.0.0.
LOG_LEVEL=info           # debug | info | warn | error. Unrecognized values fall back to info with warning.
ALERT_DB_PATH=alerts.db  # SQLite file holding alerts, encrypted tokens/credentials, OAuth clients, audit trail. On Fly.io must live on a mounted volume (e.g. /data/alerts.db).
# DEV_MODE=true          # Dev features: free billing tier, pprof endpoints, relaxed envcheck. NEVER set on hosted/production.
# CI=true                # Set by CI runners. Some tests skip or branch on this.
# FLY_REGION=bom         # Set automatically by Fly.io (3-4 lowercase letters). Used in logs and server_version tool.
# ADMIN_ENDPOINT_SECRET_PATH=   # Secret URL segment for Prometheus /metrics. Uses a random suffix so scrapers need the exact path.
# EXCLUDED_TOOLS=               # Comma-separated MCP tool names to disable at registration.

# --- Optional features ---

# Admin role & dashboard
ADMIN_EMAILS=                   # Comma-separated emails granted /admin/ops access.
# ADMIN_PASSWORD=               # First-boot password for admin login. Hashed with bcrypt cost 12 and stored; clear after first successful login.

# Google SSO for admin dashboard
# GOOGLE_CLIENT_ID=             # OAuth client ID from Google Cloud Console.
# GOOGLE_CLIENT_SECRET=         # OAuth client secret. Required if GOOGLE_CLIENT_ID is set.

# Telegram alerts + trading bot
# TELEGRAM_BOT_TOKEN=           # BotFather token. Enables /buy /sell /setalert + morning + EOD briefings.

# Stripe billing (paid tiers)
# STRIPE_SECRET_KEY=            # sk_live_... or sk_test_... Non-empty enables billing middleware outside DEV_MODE.
# STRIPE_WEBHOOK_SECRET=        # whsec_... Signature secret for /stripe/webhook.
# STRIPE_PRICE_SOLO_PRO=        # Stripe price ID for Solo Pro tier.
# STRIPE_PRICE_PRO=             # Stripe price ID for Pro tier.
# STRIPE_PRICE_PREMIUM=         # Stripe price ID for Premium tier.

# Path 2 compliance: order-placement tool gate
# Default false (read-only hosted mode per NSE/INVG/69255 Annexure I Para 2.8).
# Set true only on local single-user deployments where the operator accepts liability.
# ENABLE_TRADING=false          # true | false (case-insensitive). Invalid values abort startup.

# MCP Apps widgets
# MCP_UI_ENABLED=true           # Set "false" to skip widget registration for hosts that can't render ui:// resources.

# Audit log retention
# AUDIT_RETENTION_DAYS=90       # In-app retention for audit rows. Older rows are flagged with a chain-break marker (default 90).

# Audit hash-chain external publishing (SEBI CSCRF tamper-evidence anchor).
# Periodically uploads the chain tip (entry_hash + count) to S3-compatible
# storage, HMAC-SHA256 signed. All four core vars must be set together or
# all four unset — partial configuration aborts startup.
# AUDIT_HASH_PUBLISH_S3_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
# AUDIT_HASH_PUBLISH_BUCKET=kite-mcp-audit-hashes
# AUDIT_HASH_PUBLISH_ACCESS_KEY=
# AUDIT_HASH_PUBLISH_SECRET_KEY=
# AUDIT_HASH_PUBLISH_REGION=auto            # Optional. Default: auto.
# AUDIT_HASH_PUBLISH_INTERVAL=1h            # Optional Go duration. Default 1h. Invalid values keep the default with a warning.
# AUDIT_HASH_PUBLISH_KEY=                   # Optional dedicated HMAC key. Defaults to OAUTH_JWT_SECRET.

# TLS self-host (off-Fly.io VPS / bare-metal / on-prem). Leave unset on
# Fly.io / Cloudflare-fronted deployments — those terminate TLS upstream
# and the binary serves plain HTTP on internal_port. See docs/tls-self-host.md.
# When TLS_AUTOCERT_DOMAIN is set, the server binds :443 with autocert +
# :80 for ACME http-01 challenges + 301 redirects to HTTPS. APP_HOST and
# APP_PORT are ignored in this mode (TLS uses the privileged port :443).
# TLS_AUTOCERT_DOMAIN=mcp.example.com       # Single hostname (comma-list, bare IPs, wildcards rejected).
# TLS_AUTOCERT_CACHE_DIR=/var/lib/kite-mcp/autocert   # MUST be on persistent storage. Default: ${HOME}/.cache/kite-mcp/autocert.

