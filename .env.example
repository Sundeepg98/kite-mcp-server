# Kite MCP Server — Environment Configuration
# =============================================
# Copy this file to ".env" and update with your actual values.
# Register at https://developers.kite.trade/signup for Kite API credentials.

# === Required for multi-user HTTP mode ===
OAUTH_JWT_SECRET=your-secret-key-here
EXTERNAL_URL=http://localhost:8080

# === Kite Connect (alternative to OAuth — single-user mode) ===
KITE_API_KEY=
KITE_API_SECRET=
# KITE_ACCESS_TOKEN=  # Dev only — bypasses browser login

# === Server ===
APP_MODE=http
APP_PORT=8080
APP_HOST=0.0.0.0
LOG_LEVEL=info
ALERT_DB_PATH=alerts.db

# === Admin ===
ADMIN_EMAILS=your-email@gmail.com
ADMIN_PASSWORD=your-first-boot-password
# ADMIN_ENDPOINT_SECRET_PATH=  # Secret URL path for Prometheus metrics
# EXCLUDED_TOOLS=  # Comma-separated tool names to disable

# === Google SSO (optional — admin dashboard) ===
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# === Stripe Billing (optional — enable paid tiers) ===
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# STRIPE_PRICE_PRO=
# STRIPE_PRICE_PREMIUM=

# === Telegram Alerts (optional) ===
# TELEGRAM_BOT_TOKEN=

# === Litestream Backup (optional — SQLite replication to R2/S3) ===
# LITESTREAM_BUCKET=
# LITESTREAM_R2_ACCOUNT_ID=
# LITESTREAM_ACCESS_KEY_ID=
# LITESTREAM_SECRET_ACCESS_KEY=
