# Environment files
.env
.env.local
.env.*.local

# Local dev launcher copies — keep literal credentials out of git
# (canonical templates run-server.cmd / run-server-oauth.cmd are tracked but
# have no literal secrets; users copy them to *.local.cmd to add their own.)
*.local.cmd
run-server.local.*
run-server-oauth.local.*

# Go build artifacts
*.exe
*.exe~
*.dll
*.so
*.dylib
*.bin
kite-mcp-server
main

# Go test files
*.test
*.prof
coverage.out
coverage.html

# Go module cache
go.sum.backup

# Temporary files
*.tmp
*.temp
*.log
*.pid
*.lock

# OS generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# IDE and editor files
.vscode/
.idea/
*.swp
*.swo
*~
.project
.settings/
*.sublime-project
*.sublime-workspace

# Nix specific
.direnv/
result
result-*

# Just cache
.just/

# Build directories
build/
dist/
target/

# Documentation build artifacts
docs/

# Local data files
instruments.json
*.csv
*.xlsx

# Legacy/old files
oldpy/

# Runtime files
*.pid
*.sock

# Go vendor directory — 241 MB, generated via `go mod vendor` (see docs/kite-version-hedge.md)
vendor/

# Test binaries and artifacts
test-binary
kite-mcp-server-*

.memory

# Local files
*.local**.out
*.out
tmp/
*.html

# Root-level build/test artifacts (pre-launch hygiene — leading / anchors to repo root only)
/*.out
/*.exe
/*.cov
/coverage.out
/coverage.html
/app_*.html
/kite-mcp-server
/kite-mcp-test*

# Root-level WSL2-built CLI binaries — `go test` and `go build` in WSL produce
# ELF binaries here from cmd/ subdirs. Sources are tracked in cmd/{name}/;
# the built artifacts at repo root are throwaway.
/dr-decrypt-probe
/event-graph
/rotate-key

# Coverage outputs anywhere in .research/ — these accumulate from go-test
# coverage runs and are transient (not the canonical codecov reports).
.research/*.cov

# Ad-hoc commit-message draft files — produced as scratch by past dispatch
# work; each was used once via `git commit -F <file>` then orphaned. The
# committed content lives in the commit messages themselves; these scratch
# copies are duplicates.
.research/_*.txt
.research/*-msg.txt
.research/*_msg.txt

# Scratch / one-off experiments in .claude/ that aren't config
.claude/tst.js

# Root-level scratch notes and test dumps (not the canonical docs — those live in .research/ or docs/)
/admin.md
/api.md
/ch.md
/mod.md
/req.md
/gen_ref.md
/mcp_schema.json
/test_err.txt
/test_out.txt

# Playwright e2e suite (tests/e2e/)
tests/e2e/node_modules/
tests/e2e/playwright-report/
tests/e2e/test-results/
tests/e2e/blob-report/
tests/e2e/playwright/.cache/
# Lockfile is intentionally NOT ignored once committed; pre-bake leave room
# for the first `npm install` to produce one without churning history.
